# Copy this to .env.local and fill in your values
# Get Supabase URL + anon key from: supabase.com → your project → Settings → API

VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# The shared password for the gate page
VITE_SHARED_GATE_PASSWORD=your-secret-password-here
